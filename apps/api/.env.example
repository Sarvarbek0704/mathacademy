# =============================================================================
#  MathAcademy API — environment template
#
#  Usage:  cp .env.example .env   then fill in the real values.
#  .env is git-ignored and must never be committed.
# =============================================================================

DATABASE_URL="postgresql://postgres:root@localhost:5432/academy_test?schema=public"

PORT=4000
NODE_ENV="development"
WEB_PORT=8080

UPLOAD_DIR="uploads"
MAX_UPLOAD_MB=25

# ⚠️  Generate real secrets for anything that is not local:
#       openssl rand -base64 64
#     Access and refresh secrets MUST differ — otherwise an access token can be
#     replayed as a refresh token.
JWT_ACCESS_SECRET="jwt_access"
JWT_REFRESH_SECRET="jwt_secret"
ACCESS_TOKEN_TTL="15h"
REFRESH_TOKEN_DAYS="30"

COOKIE_NAME_REFRESH="madc_rt"
COOKIE_DOMAIN="localhost"
COOKIE_SECURE="false"
COOKIE_SAME_SITE="lax"

BCRYPT_ROUNDS="12"
RATE_LIMIT_TTL="60"
RATE_LIMIT_MAX="100"

ENABLE_SWAGGER="true"
ENABLE_CORS="true"

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

MIN_PASSWORD_LENGTH=6
PASSWORD_COMPLEXITY=true

MAX_SESSIONS_PER_USER=10
SESSION_INACTIVITY_TIMEOUT=86400

# =============================================================================
#  Seed passwords  (prisma/seed.ts)
# =============================================================================
#
#  The seed creates privileged accounts (superadmin, teachers, guardians).
#
#  Outside production these may be left blank — the seed falls back to the
#  documented demo passwords so `npm run seed` works with no setup.
#
#  ⚠️  With NODE_ENV=production the seed REFUSES to run unless:
#        1. ALLOW_SEED=true is set explicitly, and
#        2. every SEED_* value below is provided.
#
#      There are no production fallbacks by design. Seeding a live tenant with
#      publicly known passwords is how a superadmin account gets handed to
#      whoever reads the repository.
#
SEED_ADMIN_PASSWORD=
SEED_DEMO_PASSWORD=
SEED_TEACHER_PASSWORD=
SEED_GUARDIAN_PASSWORD=

# Set to "true" only when you intentionally seed a production database.
ALLOW_SEED=
